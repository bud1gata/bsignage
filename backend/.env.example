# MongoDB connection string
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/bsignage

# JWT secret key (change this!)
JWT_SECRET=your_jwt_secret_key_here

# Server port
PORT=5003

# Public base URL of the backend (used for uploaded file URLs)
# Set this to your production domain, e.g. https://api.yourdomain.com
BASE_URL=http://localhost:5003

# Allowed CORS origin (frontend URL)
# Set to your frontend production URL, e.g. https://yourdomain.com
# Use * to allow all origins (not recommended for production)
CORS_ORIGIN=*
